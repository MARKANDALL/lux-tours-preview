        )}

        {/* BEHIND THE SCENES MODAL */}
        {behindScenesOpen && (
          <BehindScenesModal
            scenario={PICKER_SCENARIOS[pickerIdx]}
            onClose={() => setBehindScenesOpen(false)}
          />
